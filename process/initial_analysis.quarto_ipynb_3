      "source": [
        "## Descriptive statistics\n",
        "\n",
        "### Numerical summary"
      ],
      "id": "25a148d3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "df[[\"Age\", \"Height (CM)\", \"Weight (KG)\", \"BMI\", \"Fasting\"]].describe()"
