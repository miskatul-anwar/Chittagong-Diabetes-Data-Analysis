    "## Standardize Fasting Column to Numerical Values\n",
    "\n",
    "Replace the original Fasting column with extracted numerical values, removing units and non-numeric characters (e.g., \"10.0MMOL\" → 10.0):"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "d21194e9",
   "metadata": {},
   "outputs": [],
   "source": [
    "import re   \n",
    "def extract_numerical_value(value):\n",
    "    if pd.isna(value):\n",
    "        return None\n",
    "    match = re.search(r\"(\\d+\\.?\\d*)\", str(value))\n",
    "    return float(match.group(1)) if match else None\n",
    "df[\"Fasting\"] = df[\"Fasting\"].apply(extract_numerical_value)\n",
    "df[\"Fasting\"] = df[\"Fasting\"].astype(float)\n",
    "df.dropna(subset=[\"Fasting\"], inplace=True)"
   ]
  },
