   "cell_type": "markdown",
   "id": "fcda6655",
   "metadata": {},
   "source": [
    "## Update the Original Dataset with Cleaned Data\n",
    "\n",
    "Merge updated fasting glucose values from the supplementary dataset into the primary dataset, aligning records by ID:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "f17fc57a",
   "metadata": {},
   "outputs": [],
   "source": [
    "new_file = os.getenv(\"NEW_PATH\")\n",
    "new_df = pd.read_excel(new_file)\n",
    "new_df.drop_duplicates(subset=\"ID\", keep=\"last\", inplace=True)\n",
    "\n",
    "# Create index copies for comparison before merge\n",
    "df_before_fasting = df[[\"ID\", \"Fasting\"]].copy()\n",
    "new_df_fasting = new_df[[\"ID\", \"Fasting\"]].copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "b3ebbb09",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Perform merge using ID-based index\n",
    "df.set_index(\"ID\", inplace=True)\n",
    "new_df.set_index(\"ID\", inplace=True)\n",
    "df.update(new_df[\"Fasting\"])\n",
    "df.reset_index(inplace=True)"
   ]
  },
